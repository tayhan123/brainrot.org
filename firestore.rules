rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Reusable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validate User entity structure
    function isValidUser(data) {
      return data.uid is string &&
             data.uid == request.auth.uid &&
             data.username is string &&
             data.username.size() >= 1 &&
             data.username.size() <= 32 &&
             data.avatar is string &&
             (data.avatar == 'student' || data.avatar == 'robot' || data.avatar == 'owl' || data.avatar == 'cat') &&
             data.xp is int &&
             data.level is int &&
             data.streak is int;
    }

    // Top-level users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isOwner(userId);

      // User notes sub-collection
      match /notes/{noteId} {
        function isValidNote(data) {
          return data.id is string &&
                 data.title is string &&
                 data.title.size() <= 128 &&
                 data.content is string &&
                 data.category is string &&
                 data.createdAt is string;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNote(incoming());
        allow update: if isOwner(userId) && isValidNote(incoming());
        allow delete: if isOwner(userId);
      }

      // User history timeline accomplished items sub-collection
      match /history/{historyId} {
        function isValidHistoryItem(data) {
          return data.id is string &&
                 data.title is string &&
                 data.title.size() <= 200 &&
                 data.xp is int &&
                 data.timestamp is string;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHistoryItem(incoming());
        allow update: if isOwner(userId) && isValidHistoryItem(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
